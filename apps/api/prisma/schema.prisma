generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  active       Boolean  @default(true)
  roleId       String   @map("role_id")
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  address   String?
  active    Boolean  @default(true)
  areas     Area[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("warehouses")
}

model Area {
  id               String     @id @default(uuid())
  code             String
  name             String
  barcode          String?    @unique
  aisles           Int        @default(1) @map("aisles")
  levels           Int        @default(1) @map("levels")
  positionsPerLevel Int       @default(1) @map("positions_per_level")
  mapX             Float?     @map("map_x")
  mapZ             Float?     @map("map_z")
  warehouseId      String     @map("warehouse_id")
  warehouse        Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  locations        Location[]
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@unique([warehouseId, code])
  @@map("areas")
}

model Location {
  id            String       @id @default(uuid())
  code          String
  name          String?
  aisle         String?      @map("aisle")
  floor         String?      @map("floor")
  position      String?      @map("position")
  barcode       String?      @unique
  accessibility Int          @default(5) @map("accessibility")
  capacity      Int?         @map("capacity")
  areaId        String       @map("area_id")
  area          Area         @relation(fields: [areaId], references: [id], onDelete: Cascade)
  allocations   Allocation[]
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@unique([areaId, code])
  @@map("locations")
}

model Product {
  id            String                @id @default(uuid())
  sku           String                @unique
  name          String
  description   String?
  barcode       String?               @unique
  weight        Float?                @map("weight")
  turnoverScore Int                   @default(5) @map("turnover_score")
  quantity      Int                   @default(0)
  priorityScore Float                 @default(0) @map("priority_score")
  active        Boolean               @default(true)
  allocations   Allocation[]
  suggestions   PlacementSuggestion[]
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@map("products")
}

model Allocation {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  locationId String   @map("location_id")
  quantity   Int      @default(0)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([productId, locationId])
  @@map("allocations")
}

model PlacementSuggestion {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  fromLocationId String?  @map("from_location_id")
  toLocationId   String   @map("to_location_id")
  quantity       Int      @default(0)
  reason         String
  score          Float    @default(0)
  status         String   @default("pending")
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("placement_suggestions")
}
